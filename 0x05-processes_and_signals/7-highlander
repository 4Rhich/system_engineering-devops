#!/usr/bin/env bash
# This script displays its PID, a loop message, and traps SIGTERM
echo "$$"

# The trap MUST match the string and punctuation exactly
trap 'echo "I am invincible!!!"' SIGTERM

while true
do
    echo "To infinity and beyond"
    # sleep & wait is the most responsive way to catch signals in Bash
    sleep 2 &
    wait $!
done
